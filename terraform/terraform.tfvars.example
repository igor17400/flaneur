# Copy this to terraform.tfvars and fill in your values
# cp terraform.tfvars.example terraform.tfvars

aws_region       = "us-east-1"
instance_type    = "t3.small"       # ~$0.02/hr (~$15/month), 2GB RAM
key_name         = "my-key-pair"    # Your existing EC2 key pair name
allowed_ssh_cidr = "0.0.0.0/0"     # Restrict to your IP: "1.2.3.4/32"
mistral_api_key  = ""               # Optional: enables /api/explain endpoint
repo_url         = "https://github.com/igor17400/flaneur.git"
repo_branch      = "main"
